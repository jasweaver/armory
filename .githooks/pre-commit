#!/bin/bash
# Git pre-commit hook - Detect secrets and sensitive data before commit
# Compatible with bash 3.x (macOS default)
# Install: cp hooks/pre-commit .git/hooks/ && chmod +x .git/hooks/pre-commit

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

SECRETS_FOUND=0

echo "🔍 Scanning for secrets in staged files..."

# Check for sensitive file types
for file in $STAGED_FILES; do
    case "$file" in
        *.pem|*.key|*.p12|*.pfx|*.jks|*.keystore)
            echo -e "${RED}  ❌ $file - Private key file${NC}"
            SECRETS_FOUND=$((SECRETS_FOUND + 1))
            ;;
        id_rsa|id_dsa|id_ecdsa|id_ed25519)
            echo -e "${RED}  ❌ $file - SSH key${NC}"
            SECRETS_FOUND=$((SECRETS_FOUND + 1))
            ;;
        .env|.env.local|.env.production|.env.*)
            echo -e "${RED}  ❌ $file - Environment file${NC}"
            SECRETS_FOUND=$((SECRETS_FOUND + 1))
            ;;
        credentials.json|.netrc|.npmrc|.pypirc)
            echo -e "${RED}  ❌ $file - Credentials file${NC}"
            SECRETS_FOUND=$((SECRETS_FOUND + 1))
            ;;
    esac
done

# Combined regex for common secrets
SECRET_REGEX='AKIA[0-9A-Z]{16}'
SECRET_REGEX="$SECRET_REGEX|ghp_[0-9a-zA-Z]{36}"
SECRET_REGEX="$SECRET_REGEX|github_pat_[0-9a-zA-Z_]{82}"
SECRET_REGEX="$SECRET_REGEX|glpat-[0-9a-zA-Z_-]{20}"
SECRET_REGEX="$SECRET_REGEX|xox[baprs]-[0-9a-zA-Z]{10,48}"
SECRET_REGEX="$SECRET_REGEX|sk_live_[0-9a-zA-Z]{24,}"
SECRET_REGEX="$SECRET_REGEX|pk_live_[0-9a-zA-Z]{24,}"
SECRET_REGEX="$SECRET_REGEX|AIza[0-9A-Za-z_-]{35}"
SECRET_REGEX="$SECRET_REGEX|-----BEGIN (RSA|DSA|EC|OPENSSH|PGP) PRIVATE KEY"

# Scan file contents
for file in $STAGED_FILES; do
    [ ! -f "$file" ] && continue
    
    # Skip binary files
    if file "$file" 2>/dev/null | grep -q "binary"; then
        continue
    fi
    
    CONTENT=$(git show ":$file" 2>/dev/null)
    
    if echo "$CONTENT" | grep -qE "$SECRET_REGEX"; then
        LINE_NUMS=$(echo "$CONTENT" | grep -nE "$SECRET_REGEX" | head -3 | cut -d: -f1 | tr '\n' ',' | sed 's/,$//')
        echo -e "${RED}  ❌ $file:$LINE_NUMS - Potential secret detected${NC}"
        SECRETS_FOUND=$((SECRETS_FOUND + 1))
    fi
done

if [ "$SECRETS_FOUND" -gt 0 ]; then
    echo ""
    echo -e "${RED}🚨 SECRETS DETECTED - COMMIT BLOCKED${NC}"
    echo ""
    echo -e "${YELLOW}How to fix:${NC}"
    echo "  1. Remove the secret from the file"
    echo "  2. Use environment variables instead"
    echo "  3. Add to .gitignore if needed"
    echo ""
    echo "  To bypass: git commit --no-verify"
    exit 1
else
    echo -e "${GREEN}✅ No secrets detected${NC}"
    exit 0
fi
